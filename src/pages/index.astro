---
import Layout from '../layouts/Layout.astro';

const hostname = Astro.url.hostname;
const isLondon = hostname === 'london.citytrades.uk';
const isNational = hostname === 'nationalhiresolutions.citytrades.uk';

const featuredBusiness = {
  name: "National Hire Solutions Limited",
  verified: true,
  trade: "🚜 Plant & Tool Hire",
  desc: "Nationwide plant and tool hire for construction and agricultural projects. Telehandlers, forklifts, powered access, and more.",
  rating: "5.0",
  reviews: "5",
  phone: "0333 006 2011",
  address: "115 Meadow Rd, Wythall, Birmingham B47 6EQ",
};

const londonData = {
  name: "London",
  about: "London's construction and trades industry is one of the largest in Europe. Electricians are particularly sought after due to the volume of commercial fit-outs and growing demand for EV charger installations. Plumbers handle everything from Victorian drainage systems in Islington to modern underfloor heating in new-build developments. Carpenters and joiners work extensively on shopfitting, bespoke wardrobes, and heritage restoration. Heating engineers are in high demand for boiler replacements, and painters see peak seasons around the property market in spring and autumn.",
  businesses: [
    {
      name: "National Hire Solutions Limited",
      verified: true,
      trade: "🚜 Plant & Tool Hire",
      tag: "Nationwide plant and tool hire for construction and agricultural projects",
      rating: "5.0",
      reviews: "5",
      phone: "0333 006 2011",
    },
  ],
};

const cities = [
  { name: "London", slug: "london" },
];
---

<Layout title={isLondon ? "London Tradesmen - CityTrades UK" : isNational ? "National Hire Solutions - CityTrades UK" : "CityTrades UK - Find Trusted Local Tradesmen"} description={isLondon ? "Find trusted tradesmen in London. Vetted professionals for every job." : isNational ? "Professional tradesmen staffing across the UK." : "Find vetted, reliable tradesmen in your city. From emergency repairs to full renovations."}>
  {isLondon ? (
    <!-- London Page -->
    <>
      <section style="text-align:center;background:linear-gradient(135deg,#0052a2 0%,#003d7a 100%);padding:60px 20px">
        <div style="max-width:1200px;margin:0 auto;padding:0 16px">
          <h1 style="margin-bottom:12px;font-size:clamp(28px,6vw,44px);font-weight:800;line-height:1.1">London Tradesmen</h1>
          <p style="opacity:.8;font-size:clamp(14px,3vw,18px);max-width:600px;margin:0 auto">{londonData.businesses.length} verified business serving London, Greater London</p>
        </div>
      </section>

      <section style="padding:60px 20px;background:#111827">
        <div style="max-width:1200px;margin:0 auto;padding:0 16px">
          <h2 style="margin-bottom:20px;font-size:clamp(22px,5vw,32px);font-weight:800;text-align:center">About London Trades</h2>
          <p style="opacity:.8;max-width:800px;margin:0 auto;font-size:16px;line-height:1.8;text-align:center">{londonData.about}</p>
        </div>
      </section>

      <section style="padding:60px 20px;background:#0f172a">
        <div style="max-width:1200px;margin:0 auto;padding:0 16px">
          <h2 style="margin-bottom:32px;font-size:clamp(22px,5vw,32px);font-weight:800;text-align:center">Recommended Local Businesses</h2>
          <div style="display:grid;gap:20px">
            {londonData.businesses.map(biz => (
              <div style="background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);border-radius:16px;padding:28px;transition:all 0.2s">
                <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:16px">
                  <div>
                    <div style="margin-bottom:8px;font-size:20px;font-weight:800">
                      {biz.name} {biz.verified && <span style="color:#fff;background:#16a34a;border-radius:6px;padding:4px 10px;font-size:12px;font-weight:600;margin-left:8px">Verified</span>}
                    </div>
                    <div style="color:#fdbf0a;margin-bottom:6px;font-size:15px;font-weight:600">{biz.trade}</div>
                    <div style="opacity:.7;margin-bottom:8px;font-size:14px">{biz.tag}</div>
                    <div style="opacity:.6;font-size:13px">★ {biz.rating} ({biz.reviews} reviews) · 📞 {biz.phone} · 📍 {featuredBusiness.address}</div>
                  </div>
                  <a href="https://www.nationalhiresolutions.co.uk/" target="_blank" rel="noopener" style="color:#111827;background:#fdbf0a;border-radius:10px;padding:12px 24px;font-size:14px;font-weight:700;white-space:nowrap;transition:all 0.2s">Visit Website</a>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    </>
  ) : isNational ? (
    <!-- National Hire Solutions Page -->
    <>
      <section style="text-align:center;background:linear-gradient(135deg,#0052a2 0%,#003d7a 100%);padding:60px 20px">
        <div style="max-width:1200px;margin:0 auto;padding:0 16px">
          <h1 style="margin-bottom:12px;font-size:clamp(28px,6vw,44px);font-weight:800;line-height:1.1">National Hire Solutions Limited</h1>
          <p style="opacity:.8;font-size:clamp(14px,3vw,18px);max-width:600px;margin:0 auto">Plant & Tool Hire Nationwide!</p>
          <span style="color:#fff;background:#16a34a;border-radius:8px;padding:6px 16px;font-size:13px;font-weight:600;display:inline-block;margin-top:16px">Verified</span>
        </div>
      </section>

      <section style="padding:60px 20px;background:#111827">
        <div style="max-width:1200px;margin:0 auto;padding:0 16px">
          <div style="background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);border-radius:16px;padding:40px">
            <div style="display:flex;align-items:center;gap:10px;margin-bottom:24px">
              <span style="color:#fdbf0a;letter-spacing:2px;font-size:18px">★★★★★</span>
              <span style="opacity:.7;font-size:15px">{featuredBusiness.rating} ({featuredBusiness.reviews} reviews)</span>
            </div>
            <p style="opacity:.8;line-height:1.8;margin-bottom:32px;font-size:16px;max-width:800px">
              National Hire Solutions is a leading plant and tool hire company serving construction and agricultural projects across the UK. From telehandlers and forklifts to powered access equipment and excavators, we provide a vast selection of quality machinery with expert support.
            </p>
            <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:20px;margin-bottom:32px">
              <div style="background:rgba(253,191,10,0.1);border:1px solid rgba(253,191,10,0.2);border-radius:12px;padding:24px;text-align:center">
                <div style="font-size:2rem;font-weight:800;color:#fdbf0a">Nationwide</div>
                <div style="opacity:.7;font-size:14px;margin-top:4px">UK Coverage</div>
              </div>
              <div style="background:rgba(253,191,10,0.1);border:1px solid rgba(253,191,10,0.2);border-radius:12px;padding:24px;text-align:center">
                <div style="font-size:2rem;font-weight:800;color:#fdbf0a">10+</div>
                <div style="opacity:.7;font-size:14px;margin-top:4px">Equipment Categories</div>
              </div>
              <div style="background:rgba(253,191,10,0.1);border:1px solid rgba(253,191,10,0.2);border-radius:12px;padding:24px;text-align:center">
                <div style="font-size:2rem;font-weight:800;color:#fdbf0a">{featuredBusiness.rating}</div>
                <div style="opacity:.7;font-size:14px;margin-top:4px">Google Rating</div>
              </div>
            </div>
            <h3 style="font-size:1.3rem;font-weight:700;margin-bottom:16px">Services</h3>
            <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:10px;margin-bottom:32px">
              {['Telehandlers','Plant Hire','Forklifts','Powered Access','Site Security','Operators','Site Fencing','Attachments'].map(s => (
                <span style="background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);border-radius:8px;padding:10px 16px;font-size:14px;text-align:center">{s}</span>
              ))}
            </div>
            <div style="display:flex;gap:16px;flex-wrap:wrap">
              <a href="tel:+443330062011" style="cursor:pointer;border:none;border-radius:10px;padding:16px 32px;font-size:16px;font-weight:700;display:inline-flex;color:#111827;background:#fdbf0a;transition:all 0.2s">Call: 0333 006 2011</a>
              <a href="https://www.nationalhiresolutions.co.uk/" target="_blank" rel="noopener" style="cursor:pointer;border-radius:10px;padding:16px 32px;font-size:16px;font-weight:700;display:inline-flex;color:#fff;border:2px solid rgba(255,255,255,0.2);transition:all 0.2s">Visit Website →</a>
            </div>
          </div>
        </div>
      </section>
    </>
  ) : (
    <!-- Homepage -->
    <>
      <section style="text-align:center;background:linear-gradient(135deg,#111827 0%,#1e293b 100%);padding:80px 20px">
        <div style="max-width:1200px;margin:0 auto;padding:0 16px">
          <h1 style="margin-bottom:20px;font-size:clamp(32px,7vw,52px);font-weight:800;line-height:1.1">
            Find Trusted Tradesmen<br/>in Your City
          </h1>
          <p style="opacity:.7;max-width:550px;margin:0 auto 36px;font-size:clamp(16px,3.5vw,20px);line-height:1.6">
            Vetted professionals for every job. From emergency repairs to full renovations.
          </p>
          <div style="flex-wrap:wrap;justify-content:center;gap:16px;display:flex">
            <a href="https://london.citytrades.uk/" style="cursor:pointer;border:none;border-radius:10px;align-items:center;gap:8px;padding:16px 32px;font-size:16px;font-weight:700;display:inline-flex;color:#111827;background:#fdbf0a;transition:all 0.2s">Browse London</a>
            <a href="https://nationalhiresolutions.citytrades.uk/" style="cursor:pointer;border:none;border-radius:10px;align-items:center;gap:8px;padding:16px 32px;font-size:16px;font-weight:700;display:inline-flex;color:#111827;background:#fff;transition:all 0.2s">View National Hire Solutions</a>
          </div>
        </div>
      </section>

      <section style="padding:60px 20px;background:#0f172a">
        <div style="max-width:1200px;margin:0 auto;padding:0 16px">
          <h2 style="margin-bottom:12px;font-size:clamp(24px,5vw,36px);font-weight:800;text-align:center">Recommended Local Businesses</h2>
          <p style="opacity:.6;text-align:center;margin-bottom:32px;font-size:15px">Top-rated professionals recommended by homeowners</p>
          <a href="https://nationalhiresolutions.citytrades.uk/" style="text-align:left;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);border-radius:16px;flex-direction:column;gap:16px;padding:32px;transition:all 0.2s;display:flex;max-width:700px;margin:0 auto;text-decoration:none;color:inherit">
            <div>
              <div style="margin-bottom:8px;font-size:22px;font-weight:800">{featuredBusiness.name} {featuredBusiness.verified && <span style="color:#fff;vertical-align:middle;background:#16a34a;border-radius:6px;padding:4px 10px;font-size:12px;font-weight:600;margin-left:8px">Verified</span>}</div>
              <div style="color:#fdbf0a;margin-bottom:8px;font-size:16px;font-weight:600">{featuredBusiness.trade}</div>
              <div style="opacity:.7;font-size:15px;line-height:1.6">{featuredBusiness.desc}</div>
              <div style="opacity:.5;font-size:13px;margin-top:8px">📍 {featuredBusiness.address}</div>
            </div>
            <div style="text-align:left;opacity:.8;white-space:nowrap;font-size:15px">
              <span style="color:#fdbf0a;letter-spacing:2px">★★★★★</span> {featuredBusiness.rating} ({featuredBusiness.reviews})
              <div style="color:#fdbf0a;margin-top:8px;font-weight:700">Visit Website →</div>
            </div>
          </a>
        </div>
      </section>

      <section style="text-align:center;padding:60px 20px;background:linear-gradient(135deg,#0052a2 0%,#003d7a 100%)">
        <div style="max-width:1200px;margin:0 auto;padding:0 16px">
          <h2 style="margin-bottom:12px;font-size:clamp(24px,5vw,36px);font-weight:800">Cities We Cover</h2>
          <p style="opacity:.7;margin-bottom:32px;font-size:16px">Trusted tradesmen in cities across the UK</p>
          <div style="grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:16px;display:grid;max-width:600px;margin:0 auto">
            {cities.map(city => (
              <a href={`https://${city.slug}.citytrades.uk/`} style="text-align:center;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.2);border-radius:12px;padding:20px;font-size:16px;font-weight:700;transition:all 0.2s;display:block">
                📍 {city.name}
              </a>
            ))}
          </div>
        </div>
      </section>
    </>
  )}
</Layout>
