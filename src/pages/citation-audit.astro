---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Citation Audit - CityTrades UK" description="Free citation audit for your trade business. Check your online listings across the web.">
  <section style="text-align:center;background:#0052a2;padding:clamp(40px,8vw,64px) 24px">
    <div style="max-width:900px;margin:0 auto">
      <h1 style="margin-bottom:12px;font-size:clamp(24px,6vw,40px);font-weight:800">Free Citation Audit</h1>
      <p style="opacity:.8;font-size:clamp(13px,3vw,16px)">Check your business listings across 50+ directories</p>
    </div>
  </section>

  <section style="text-align:center;padding:48px 24px">
    <div style="max-width:900px;margin:0 auto">
      <h2 style="margin-bottom:16px;font-size:clamp(20px,5vw,28px);font-weight:800">What is a citation audit?</h2>
      <p style="opacity:.7;max-width:700px;margin:0 auto 24px;font-size:15px;line-height:1.8">
        A citation audit checks your business name, address, and phone number (NAP) across all the major online directories. Inconsistent information hurts your local SEO rankings. We check Yell, Thomson Local, Checkatrade, Bark, TrustATrader, and 45+ other UK directories.
      </p>
      <p style="opacity:.7;max-width:700px;margin:0 auto 24px;font-size:15px;line-height:1.8">
        Get your free report showing exactly where your business is listed, what information is correct, and what needs fixing.
      </p>
      <a href="https://citytrades.uk/#contact" style="cursor:pointer;border:none;border-radius:8px;padding:14px 28px;font-size:15px;font-weight:700;display:inline-flex;color:#111827;background:#fdbf0a;margin-top:16px">Get Your Free Audit</a>
    </div>
  </section>
</Layout>
