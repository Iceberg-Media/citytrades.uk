---
import Layout from '../layouts/Layout.astro';
---

<Layout title="National Hire Solutions - CityTrades UK" description="Professional tradesmen staffing across the UK. Verified and vetted builders, plumbers, electricians, and more.">
  <section style="text-align:center;background:#0052a2;padding:clamp(40px,8vw,64px) 24px">
    <div style="max-width:900px;margin:0 auto">
      <h1 style="margin-bottom:6px;font-size:clamp(24px,6vw,40px);font-weight:800">National Hire Solutions</h1>
      <p style="opacity:.8;font-size:clamp(13px,3vw,16px)">Professional tradesmen staffing across the UK</p>
      <span style="color:#fff;background:#16a34a;border-radius:6px;padding:4px 12px;font-size:12px;font-weight:600;display:inline-block;margin-top:12px">Verified</span>
    </div>
  </section>

  <section style="padding:48px 24px">
    <div style="max-width:900px;margin:0 auto">
      <div style="background:#ffffff0f;border:1px solid #ffffff1a;border-radius:12px;padding:32px;margin-bottom:24px">
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:16px">
          <span style="color:#fdbf0a;letter-spacing:2px">★★★★★</span>
          <span style="opacity:.7;font-size:14px">4.8 (342 reviews)</span>
        </div>
        <p style="opacity:.8;line-height:1.8;margin-bottom:16px">
          National Hire Solutions connects you with vetted, qualified tradesmen for residential and commercial projects. From single-day repairs to full renovations, we have the right people for the job.
        </p>
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:16px;margin-bottom:24px">
          <div style="background:#ffffff0a;border-radius:8px;padding:16px;text-align:center">
            <div style="font-size:1.5rem;font-weight:800;color:#fdbf0a">500+</div>
            <div style="opacity:.7;font-size:13px">Vetted Tradesmen</div>
          </div>
          <div style="background:#ffffff0a;border-radius:8px;padding:16px;text-align:center">
            <div style="font-size:1.5rem;font-weight:800;color:#fdbf0a">50+</div>
            <div style="opacity:.7;font-size:13px">UK Cities</div>
          </div>
          <div style="background:#ffffff0a;border-radius:8px;padding:16px;text-align:center">
            <div style="font-size:1.5rem;font-weight:800;color:#fdbf0a">4.8</div>
            <div style="opacity:.7;font-size:13px">Average Rating</div>
          </div>
        </div>
        <h3 style="font-size:1.2rem;font-weight:700;margin-bottom:12px">Services</h3>
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:8px;margin-bottom:24px">
          <span style="background:#ffffff0a;border-radius:6px;padding:8px 12px;font-size:13px">Builders</span>
          <span style="background:#ffffff0a;border-radius:6px;padding:8px 12px;font-size:13px">Plumbers</span>
          <span style="background:#ffffff0a;border-radius:6px;padding:8px 12px;font-size:13px">Electricians</span>
          <span style="background:#ffffff0a;border-radius:6px;padding:8px 12px;font-size:13px">Carpenters</span>
          <span style="background:#ffffff0a;border-radius:6px;padding:8px 12px;font-size:13px">Painters</span>
          <span style="background:#ffffff0a;border-radius:6px;padding:8px 12px;font-size:13px">Roofers</span>
          <span style="background:#ffffff0a;border-radius:6px;padding:8px 12px;font-size:13px">Heating Engineers</span>
          <span style="background:#ffffff0a;border-radius:6px;padding:8px 12px;font-size:13px">Landscapers</span>
        </div>
        <div style="display:flex;gap:12px;flex-wrap:wrap">
          <a href="tel:08001234567" style="cursor:pointer;border:none;border-radius:8px;padding:14px 28px;font-size:15px;font-weight:700;display:inline-flex;color:#111827;background:#fdbf0a">Call: 0800 123 4567</a>
          <a href="https://citytrades.uk/" style="cursor:pointer;border-radius:8px;padding:14px 28px;font-size:15px;font-weight:700;display:inline-flex;color:#fff;border:1px solid #ffffff26">Back to CityTrades</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
