---
import Layout from '../layouts/Layout.astro';

const business = {
  name: "National Hire Solutions Limited",
  tagline: "Plant & Tool Hire Nationwide!",
  category: "Plant and machinery hire",
  address: "115 Meadow Rd, Wythall, Birmingham B47 6EQ",
  phone: "0333 006 2011",
  phoneLink: "+443330062011",
  email: "sales@nationalhiresolutions.co.uk",
  website: "https://www.nationalhiresolutions.co.uk/",
  rating: "5.0",
  reviews: "5",
  placeId: "ChIJU3NwouiBekgRGQjJ8NsH0jg",
  cid: "4094343652452141081",
  lat: "52.3760913",
  lng: "-1.8829862",
  heroImage: "https://lh3.googleusercontent.com/gps-cs-s/AHRPTWnDcU35EDjeIXBaHrgy-FTx-mkUBMj7nw51LoLp6jnSwolVWOZO7ILO07s6RVHdGX7WFK1WZoFPAljn5P6WOLpkFwc0htdjxkDF4ChlQtSMQwuSrUx-9C2o7ttPR02SvEib0sCy2F3sTUHr=w1200-h630-k-no",
  hours: {
    monday: "07:00 AM - 6:00 PM",
    tuesday: "07:00 AM - 6:00 PM",
    wednesday: "07:00 AM - 6:00 PM",
    thursday: "07:00 AM - 6:00 PM",
    friday: "07:00 AM - 6:00 PM",
    saturday: "07:00 AM - 12:00 PM",
    sunday: "Closed"
  },
  description: "National Hire Solutions is a leading plant and tool hire company serving construction and agricultural projects across the UK. From telehandlers and forklifts to powered access equipment and excavators, we provide a vast selection of quality machinery with expert support. Our nationwide coverage ensures you get the right equipment at the right price, anywhere in the UK.",
  services: [
    { name: "Telehandlers", icon: "🏗️" },
    { name: "Roto Telehandlers & Heavy Lift", icon: "🔄" },
    { name: "Plant Hire", icon: "🚜" },
    { name: "Forklifts", icon: "🔧" },
    { name: "Powered Access Hire", icon: "📐" },
    { name: "Site Security Camera PODS", icon: "📹" },
    { name: "Operators", icon: "👷" },
    { name: "Site Fencing", icon: "🚧" },
    { name: "Attachments", icon: "⚙️" },
    { name: "Health & Safety", icon: "🛡️" }
  ]
};
---

<Layout 
  title={`${business.name} - ${business.tagline} | CityTrades UK`} 
  description={`${business.description.substring(0, 155)}...`}
  canonical="https://nationalhiresolutions.citytrades.uk/"
>
  <!-- Hero Section -->
  <section style="background:linear-gradient(135deg,#f8fafc 0%,#e2e8f0 100%);padding:clamp(40px,8vw,80px) 24px">
    <div style="max-width:1200px;margin:0 auto;display:flex;flex-direction:column;gap:32px;align-items:center">
      <div style="text-align:center;max-width:800px">
        <h1 style="margin-bottom:16px;font-size:clamp(28px,6vw,48px);font-weight:900;color:#111827;line-height:1.1">
          {business.name}
        </h1>
        <p style="font-size:clamp(16px,3vw,20px);color:#475569;margin-bottom:8px;font-weight:600">
          {business.tagline}
        </p>
        <p style="font-size:clamp(14px,2.5vw,16px);color:#64748b;margin-bottom:24px;line-height:1.7;max-width:700px;margin-left:auto;margin-right:auto">
          {business.description}
        </p>
        <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap">
          <a href={`tel:${business.phoneLink}`} style="background:#16a34a;color:#fff;padding:14px 32px;border-radius:50px;font-weight:700;font-size:16px;text-decoration:none;display:inline-flex;align-items:center;gap:8px;transition:background 0.2s">
            📞 Call {business.phone}
          </a>
          <a href={business.website} target="_blank" rel="noopener" style="background:#fff;color:#111827;padding:14px 32px;border-radius:50px;font-weight:700;font-size:16px;text-decoration:none;display:inline-flex;align-items:center;gap:8px;border:1px solid #e2e8f0;transition:all 0.2s">
            🌐 Visit Website
          </a>
        </div>
      </div>
      <img 
        src={business.heroImage} 
        alt={`${business.name} - ${business.tagline}`}
        style="max-width:100%;height:auto;border-radius:16px;box-shadow:0 20px 60px rgba(0,0,0,0.15)"
        loading="eager"
      />
    </div>
  </section>

  <!-- Rating Badge -->
  <section style="background:#fff;padding:32px 24px;border-bottom:1px solid #e5e7eb">
    <div style="max-width:1200px;margin:0 auto;display:flex;justify-content:center;gap:32px;flex-wrap:wrap;align-items:center">
      <div style="display:flex;align-items:center;gap:8px">
        <span style="color:#f59e0b;font-size:20px">★★★★★</span>
        <span style="font-weight:700;font-size:18px;color:#111827">{business.rating}</span>
        <span style="color:#64748b;font-size:14px">({business.reviews} reviews)</span>
      </div>
      <div style="display:flex;align-items:center;gap:8px">
        <span style="background:#dcfce7;color:#16a34a;padding:4px 12px;border-radius:20px;font-size:13px;font-weight:600">✓ Verified Business</span>
      </div>
      <div style="display:flex;align-items:center;gap:8px">
        <span style="color:#64748b;font-size:14px">📍 {business.address}</span>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section style="background:#fff;padding:clamp(40px,8vw,80px) 24px">
    <div style="max-width:1200px;margin:0 auto">
      <h2 style="text-align:center;font-size:clamp(24px,5vw,36px);font-weight:900;color:#111827;margin-bottom:16px">
        Our Services
      </h2>
      <p style="text-align:center;color:#64748b;margin-bottom:48px;font-size:16px;max-width:600px;margin-left:auto;margin-right:auto">
        Comprehensive plant and tool hire solutions for construction and agricultural projects across the UK
      </p>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(250px,1fr));gap:24px">
        {business.services.map(service => (
          <div style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:16px;padding:24px;transition:all 0.2s;cursor:default">
            <div style="font-size:32px;margin-bottom:12px">{service.icon}</div>
            <h3 style="font-size:18px;font-weight:700;color:#111827;margin:0">{service.name}</h3>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact & Map Section -->
  <section style="background:#f8fafc;padding:clamp(40px,8vw,80px) 24px">
    <div style="max-width:1200px;margin:0 auto;display:grid;grid-template-columns:1fr;gap:48px">
      <!-- Contact Info -->
      <div>
        <h2 style="font-size:clamp(24px,5vw,36px);font-weight:900;color:#111827;margin-bottom:32px">
          Contact Information
        </h2>
        <div style="display:flex;flex-direction:column;gap:24px">
          <!-- Phone -->
          <div style="display:flex;gap:16px;align-items:flex-start">
            <span style="font-size:24px;min-width:32px">📞</span>
            <div>
              <div style="font-weight:600;color:#64748b;font-size:14px;margin-bottom:4px">Phone</div>
              <a href={`tel:${business.phoneLink}`} style="font-weight:700;color:#111827;font-size:18px;text-decoration:none">
                {business.phone}
              </a>
            </div>
          </div>
          <!-- Email -->
          <div style="display:flex;gap:16px;align-items:flex-start">
            <span style="font-size:24px;min-width:32px">✉️</span>
            <div>
              <div style="font-weight:600;color:#64748b;font-size:14px;margin-bottom:4px">Email</div>
              <a href={`mailto:${business.email}`} style="font-weight:700;color:#111827;font-size:18px;text-decoration:none">
                {business.email}
              </a>
            </div>
          </div>
          <!-- Address -->
          <div style="display:flex;gap:16px;align-items:flex-start">
            <span style="font-size:24px;min-width:32px">📍</span>
            <div>
              <div style="font-weight:600;color:#64748b;font-size:14px;margin-bottom:4px">Address</div>
              <div style="font-weight:700;color:#111827;font-size:18px">
                {business.address}
              </div>
            </div>
          </div>
          <!-- Hours -->
          <div style="display:flex;gap:16px;align-items:flex-start">
            <span style="font-size:24px;min-width:32px">🕐</span>
            <div style="flex:1">
              <div style="font-weight:600;color:#64748b;font-size:14px;margin-bottom:12px">Business Hours</div>
              <div style="display:flex;flex-direction:column;gap:8px">
                {Object.entries(business.hours).map(([day, hours]) => (
                  <div style="display:flex;justify-content:space-between;align-items:center;padding:8px 12px;background:#fff;border-radius:8px;border:1px solid #e5e7eb">
                    <span style="font-weight:600;color:#111827;text-transform:capitalize">{day}</span>
                    <span style={`font-weight:600;color:${hours === 'Closed' ? '#dc2626' : '#16a34a'}`}>{hours}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Google Map -->
      <div>
        <h2 style="font-size:clamp(24px,5vw,36px);font-weight:900;color:#111827;margin-bottom:32px">
          Find Us
        </h2>
        <iframe 
          title="Google Maps - National Hire Solutions"
          width="100%" 
          height="450" 
          style="border:0;border-radius:16px;box-shadow:0 10px 40px rgba(0,0,0,0.1)" 
          loading="lazy" 
          allowfullscreen 
          src={`https://www.google.com/maps/embed/v1/place?q=place_id:${business.placeId}&key=AIzaSyBFw0Qbyq9zTFTd-tUY6dZWTgaQzuU17R8`}
        ></iframe>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section style="background:linear-gradient(135deg,#0052a2 0%,#003d7a 100%);padding:clamp(40px,8vw,80px) 24px;text-align:center">
    <div style="max-width:800px;margin:0 auto">
      <h2 style="font-size:clamp(24px,5vw,36px);font-weight:900;color:#fff;margin-bottom:16px">
        Ready to Hire?
      </h2>
      <p style="color:rgba(255,255,255,0.8);font-size:18px;margin-bottom:32px;line-height:1.7">
        Get in touch with our team for a free quote or to discuss your equipment needs. We're here to help you find the right machinery at the right price.
      </p>
      <div style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap">
        <a href={`tel:${business.phoneLink}`} style="background:#fdbf0a;color:#111827;padding:16px 36px;border-radius:50px;font-weight:700;font-size:18px;text-decoration:none;display:inline-flex;align-items:center;gap:8px">
          📞 Call {business.phone}
        </a>
        <a href={`mailto:${business.email}`} style="background:rgba(255,255,255,0.1);color:#fff;padding:16px 36px;border-radius:50px;font-weight:700;font-size:18px;text-decoration:none;display:inline-flex;align-items:center:gap:8px;border:1px solid rgba(255,255,255,0.3)">
          ✉️ Send Email
        </a>
      </div>
    </div>
  </section>

  <!-- Schema.org Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": business.name,
    "description": business.description,
    "image": business.heroImage,
    "url": business.website,
    "telephone": business.phoneLink,
    "email": business.email,
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "115 Meadow Rd",
      "addressLocality": "Wythall, Birmingham",
      "postalCode": "B47 6EQ",
      "addressCountry": "GB"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": business.lat,
      "longitude": business.lng
    },
    "openingHoursSpecification": [
      { "@type": "OpeningHoursSpecification", "dayOfWeek": "Monday", "opens": "07:00", "closes": "18:00" },
      { "@type": "OpeningHoursSpecification", "dayOfWeek": "Tuesday", "opens": "07:00", "closes": "18:00" },
      { "@type": "OpeningHoursSpecification", "dayOfWeek": "Wednesday", "opens": "07:00", "closes": "18:00" },
      { "@type": "OpeningHoursSpecification", "dayOfWeek": "Thursday", "opens": "07:00", "closes": "18:00" },
      { "@type": "OpeningHoursSpecification", "dayOfWeek": "Friday", "opens": "07:00", "closes": "18:00" },
      { "@type": "OpeningHoursSpecification", "dayOfWeek": "Saturday", "opens": "07:00", "closes": "12:00" }
    ],
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": business.rating,
      "reviewCount": business.reviews,
      "bestRating": "5"
    },
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Plant & Tool Hire Services",
      "itemListElement": business.services.map(s => ({
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": s.name
        }
      }))
    },
    "sameAs": [business.website]
  })} />
</Layout>
