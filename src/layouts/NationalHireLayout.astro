---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
}

const { title, description, canonical } = Astro.props;
const url = canonical || Astro.url.href;

const business = {
  name: "National Hire Solutions",
  phone: "0333 006 2011",
  phoneLink: "+443330062011",
  email: "sales@nationalhiresolutions.co.uk",
  website: "https://www.nationalhiresolutions.co.uk/",
};
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="canonical" href={url} />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={url} />
  <meta property="og:type" content="website" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Google Analytics 4 -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-9234344VFW"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(...args: any[]){(window as any).dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-9234344VFW');
  </script>

  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif; }
    .micro-header {
      background: #fff;
      border-bottom: 1px solid #e5e7eb;
      position: sticky;
      top: 0;
      z-index: 50;
    }
    .micro-nav {
      max-width: 1200px;
      margin: 0 auto;
      padding: 12px 24px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .micro-logo {
      display: flex;
      align-items: center;
      gap: 12px;
      text-decoration: none;
      color: #111827;
    }
    .micro-logo-icon {
      width: 40px;
      height: 40px;
      background: #0052a2;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 20px;
    }
    .micro-logo-text {
      font-weight: 800;
      font-size: 18px;
    }
    .micro-nav-links {
      display: flex;
      gap: 24px;
      align-items: center;
    }
    .micro-nav-links a {
      color: #475569;
      text-decoration: none;
      font-weight: 500;
      font-size: 14px;
      transition: color 0.2s;
    }
    .micro-nav-links a:hover {
      color: #111827;
    }
    .micro-nav-phone {
      background: #16a34a;
      color: #fff !important;
      padding: 8px 16px;
      border-radius: 50px;
      font-weight: 600 !important;
    }
    .micro-footer {
      background: #f8fafc;
      border-top: 1px solid #e5e7eb;
      padding: 32px 24px;
      text-align: center;
    }
    .micro-footer-content {
      max-width: 1200px;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      gap: 16px;
      align-items: center;
    }
    .micro-footer-links {
      display: flex;
      gap: 24px;
      flex-wrap: wrap;
      justify-content: center;
    }
    .micro-footer-links a {
      color: #64748b;
      text-decoration: none;
      font-size: 14px;
    }
    .micro-footer-links a:hover {
      color: #111827;
    }
    .micro-footer-credit {
      color: #94a3b8;
      font-size: 13px;
    }
    .micro-footer-credit a {
      color: #64748b;
      text-decoration: none;
    }
    @media (max-width: 768px) {
      .micro-nav-links {
        display: none;
      }
    }
  </style>
</head>
<body>
  <!-- Header -->
  <header class="micro-header">
    <nav class="micro-nav">
      <a href="/" class="micro-logo">
        <div class="micro-logo-icon">🚜</div>
        <div class="micro-logo-text">National Hire Solutions</div>
      </a>
      <div class="micro-nav-links">
        <a href="#services">Services</a>
        <a href="#contact">Contact</a>
        <a href="#hours">Hours</a>
        <a href={`tel:${business.phoneLink}`} class="micro-nav-phone">📞 {business.phone}</a>
      </div>
    </nav>
  </header>

  <main>
    <slot />
  </main>

  <!-- Footer -->
  <footer class="micro-footer">
    <div class="micro-footer-content">
      <div class="micro-footer-links">
        <a href={business.website} target="_blank" rel="noopener">Official Website</a>
        <a href={`tel:${business.phoneLink}`}>Call Us</a>
        <a href={`mailto:${business.email}`}>Email Us</a>
        <a href="https://citytrades.uk/">Listed on CityTrades</a>
      </div>
      <div class="micro-footer-credit">
        &copy; {new Date().getFullYear()} {business.name}. All rights reserved.
      </div>
    </div>
  </footer>
</body>
</html>
