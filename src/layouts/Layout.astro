---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
}

const { title, description, canonical } = Astro.props;
const url = canonical || Astro.url.href;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="canonical" href={url} />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={url} />
  <meta property="og:type" content="website" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Google Analytics 4 -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-9234344VFW"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(...args: any[]){(window as any).dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-9234344VFW');
  </script>
</head>
<body>
  <!-- Header -->
  <header style="background:#0052a2;padding:14px 0;border-bottom:3px solid #fdbf0a">
    <div style="max-width:1200px;margin:0 auto;padding:0 16px;display:flex;justify-content:space-between;align-items:center">
      <a href="https://citytrades.uk/" style="color:#fff;align-items:center;gap:8px;font-size:20px;font-weight:800;display:flex">
        🔨 CityTrades<span style="opacity:.6;font-weight:400">.uk</span>
      </a>
      <nav style="position:relative" id="nav">
        <button id="nav-toggle" style="color:#fff;cursor:pointer;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.2);border-radius:8px;padding:8px 16px;font-size:14px;font-weight:600;transition:all 0.2s">Service Areas ▾</button>
        <div id="nav-dropdown" style="z-index:100;background:#fff;border-radius:12px;width:220px;margin-top:8px;position:absolute;right:0;overflow:hidden;box-shadow:0 12px 40px rgba(0,0,0,0.3);display:none;border:1px solid #e5e7eb">
          <a href="https://london.citytrades.uk/" style="color:#111827;padding:14px 20px;font-size:15px;font-weight:500;display:block;transition:background 0.2s;border-bottom:1px solid #f3f4f6">📍 London</a>
          <a href="https://nationalhiresolutions.citytrades.uk/" style="color:#111827;padding:14px 20px;font-size:15px;font-weight:500;display:block;transition:background 0.2s">🏗️ National Hire Solutions</a>
        </div>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <!-- Footer -->
  <footer style="background:#0a0f1a;padding:40px 0 24px;border-top:3px solid #fdbf0a">
    <div style="max-width:1200px;margin:0 auto;padding:0 16px">
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:40px;margin-bottom:40px">
        <div>
          <div style="font-size:20px;font-weight:800;color:#fff;margin-bottom:12px">🔨 CityTrades<span style="opacity:.6;font-weight:400">.uk</span></div>
          <p style="color:#94a3b8;font-size:14px;line-height:1.6">Finding trusted tradesmen in cities across the UK. Vetted professionals for every job.</p>
        </div>
        <div>
          <h4 style="color:#fff;font-weight:600;margin-bottom:16px;font-size:16px">Service Areas</h4>
          <a href="https://london.citytrades.uk/" style="display:block;color:#94a3b8;padding:6px 0;font-size:14px;transition:color 0.2s">London</a>
          <a href="https://nationalhiresolutions.citytrades.uk/" style="display:block;color:#94a3b8;padding:6px 0;font-size:14px;transition:color 0.2s">National Hire Solutions</a>
        </div>
        <div>
          <h4 style="color:#fff;font-weight:600;margin-bottom:16px;font-size:16px">Services</h4>
          <span style="display:block;color:#94a3b8;padding:6px 0;font-size:14px">Builders</span>
          <span style="display:block;color:#94a3b8;padding:6px 0;font-size:14px">Plumbers</span>
          <span style="display:block;color:#94a3b8;padding:6px 0;font-size:14px">Electricians</span>
          <span style="display:block;color:#94a3b8;padding:6px 0;font-size:14px">Carpenters</span>
        </div>
      </div>
      <div style="border-top:1px solid #1e293b;padding-top:24px;text-align:center">
        <p style="color:#64748b;font-size:13px">&copy; 2026 CityTrades UK. All rights reserved.</p>
      </div>
    </div>
  </footer>

  <script>
    document.getElementById('nav-toggle')?.addEventListener('click', () => {
      const dropdown = document.getElementById('nav-dropdown');
      if (dropdown) dropdown.style.display = dropdown.style.display === 'none' ? 'block' : 'none';
    });
    document.addEventListener('click', (e) => {
      const nav = document.getElementById('nav');
      if (nav && !nav.contains(e.target as Node)) {
        const dropdown = document.getElementById('nav-dropdown');
        if (dropdown) dropdown.style.display = 'none';
      }
    });
  </script>
</body>
</html>
